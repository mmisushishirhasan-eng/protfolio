{
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|svg|css|js|woff2|woff)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, stale-while-revalidate=43200"
        }
      ]
    }
  ]
}
